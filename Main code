import java.util.ArrayList;
import java.util.Scanner;

abstract class Patient {
    private String name;
    private int severity;

    public Patient(String name, int severity) {
        this.name = name;
        this.severity = severity;
    }

    public String getName() {
        return name;
    }

    public int getSeverity() {
        return severity;
    }

    abstract int getPriority();

    public void showInfo() {
        System.out.println("Name: " + name + " | Severity: " + severity + " | Priority: " + getPriority());
    }
}

class NormalPatient extends Patient {
    public NormalPatient(String name, int severity) {
        super(name, severity);
    }

    int getPriority() {
        return getSeverity();
    }
}

class CriticalPatient extends Patient {
    public CriticalPatient(String name, int severity) {
        super(name, severity);
    }

    int getPriority() {
        return getSeverity() + 5;
    }
}

class VIPPatient extends Patient {
    public VIPPatient(String name, int severity) {
        super(name, severity);
    }

    int getPriority() {
        return getSeverity() + 3;
    }
}

class Hospital {
    private ArrayList<Patient> list = new ArrayList<>();

    public void addPatient(Patient p) {
        list.add(p);
    }

    public void showPatients() {
        if (list.size() == 0) {
            System.out.println("No patients available.");
            return;
        }

        for (Patient p : list) {
            p.showInfo();
        }
    }

    public void treatPatient() {
        if (list.size() == 0) {
            System.out.println("No patients to treat.");
            return;
        }

        Patient highest = list.get(0);

        for (Patient p : list) {
            if (p.getPriority() > highest.getPriority()) {
                highest = p;
            }
        }

        System.out.println("\nTreating Patient:");
        highest.showInfo();
        list.remove(highest);
    }
}

public class Main {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);
        Hospital hospital = new Hospital();

        while (true) {
            System.out.println("\n1. Add Patient");
            System.out.println("2. Show Patients");
            System.out.println("3. Treat Patient");
            System.out.println("4. Exit");
            System.out.print("Choose option: ");

            int choice = sc.nextInt();

            if (choice == 1) {
                System.out.print("Enter Name: ");
                String name = sc.next();

                System.out.print("Enter Severity (1-10): ");
                int severity = sc.nextInt();

                System.out.println("Type: 1.Normal 2.Critical 3.VIP");
                int type = sc.nextInt();

                Patient p;

                if (type == 2) {
                    p = new CriticalPatient(name, severity);
                } else if (type == 3) {
                    p = new VIPPatient(name, severity);
                } else {
                    p = new NormalPatient(name, severity);
                }

                hospital.addPatient(p);
                System.out.println("Patient Added!");

            } else if (choice == 2) {
                hospital.showPatients();

            } else if (choice == 3) {
                hospital.treatPatient();

            } else if (choice == 4) {
                break;
            } else {
                System.out.println("Invalid choice!");
            }
        }
    }
}
